# ─────────────────────────────────────────────────────────────────────────────
# POKYH iOS — Konfigurationsreferenz
#
# Diese Werte werden zentral in POKYH/Config.swift gesetzt (eine einzige Quelle,
# nichts in den Views hardcoden). Diese Datei dokumentiert sie und dient als
# Vorlage, falls die App gegen eine andere WebUntis-Instanz / ein anderes Backend
# konfiguriert werden soll.
# ─────────────────────────────────────────────────────────────────────────────

# ── POKYH Backend ────────────────────────────────────────────────────────────
# Basis-URL des POKYH-Backends (HTTPS empfohlen — vermeidet ATS-Ausnahmen).
BACKEND_URL=https://api.pokyh.com

# Öffentlicher Backend-API-Key (entspricht NEXT_PUBLIC_API_KEY im Web-Frontend,
# wird ohnehin an Clients ausgeliefert).
API_KEY=your_backend_api_key_here

# Server-zu-Server-Key. Wird nach dem WebUntis-Login verwendet, um einen
# Backend-Token ohne Passwort zu beziehen.
# SICHERHEIT: gehört eigentlich nicht in einen Client — siehe README.
SERVER_KEY=your_server_key_here

# ── WebUntis ─────────────────────────────────────────────────────────────────
# Basis-URL der WebUntis-Instanz.
WEBUNTIS_BASE_URL=https://lbs-brixen.webuntis.com/WebUntis

# Schulkürzel (für ?school= und das schoolname-Cookie).
WEBUNTIS_SCHOOL=lbs-brixen

# Client-Kennung für den JSON-RPC authenticate-Call.
WEBUNTIS_CLIENT=pockyh
